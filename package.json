{
    "name": "@9c5s/node-tcnet",
    "version": "0.6.0",
    "description": "Implements the TC-Supply TCNet protocol used by ShowKontrol and ProDJLink Bridge app from Pioneer",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "homepage": "https://github.com/9c5s/node-tcnet#readme",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/9c5s/node-tcnet.git"
    },
    "files": [
        "/dist"
    ],
    "scripts": {
        "docs": "typedoc",
        "docs:watch": "typedoc --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "example": "node --import tsx examples",
        "build": "rm -rf dist && tsup && check-export-map",
        "watch": "tsc -b -w",
        "changeset": "changeset",
        "clean": "tsc -b --clean",
        "lint": "eslint .",
        "format:fix": "prettier --write \"./**/*.{ts,js,mjs,json,jsonc}\"",
        "format:check": "prettier --check \"./**/*.{ts,js,mjs,json,jsonc}\"",
        "format-pre-commit": "pretty-quick --staged --pattern '*/**/*.{ts,js,mjs,json,jsonc}'",
        "mdlint": "markdownlint-cli2 \"docs/wiki/**/*.md\" \"*.{md,MD}\" \"!CHANGELOG.md\"",
        "mdlint:fix": "markdownlint-cli2 --fix \"docs/wiki/**/*.md\" \"*.{md,MD}\" \"!CHANGELOG.md\"",
        "textlint": "textlint \"docs/wiki/**/*.md\" \"README.MD\"",
        "textlint:fix": "textlint --fix \"docs/wiki/**/*.md\" \"README.MD\""
    },
    "devDependencies": {
        "@changesets/cli": "^2.27.9",
        "@changesets/parse": "^0.4.3",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.39.4",
        "@types/node": "^25.5.0",
        "check-export-map": "^1.3.1",
        "eslint": "^9.39.4",
        "eslint-plugin-jsdoc": "^62.8.0",
        "markdownlint-cli2": "^0.21.0",
        "prettier": "^2.2.1",
        "pretty-quick": "^3.1.0",
        "textlint": "^15.5.2",
        "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "^1.0.1",
        "textlint-rule-preset-ja-technical-writing": "^12.0.2",
        "tsup": "^8.3.5",
        "tsx": "^4.19.2",
        "typedoc": "^0.28.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vitest": "^4.1.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true
    }
}
